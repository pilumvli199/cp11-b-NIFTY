# ── Upstox API ─────────────────────────

UPSTOX_ANALYTICS_TOKEN=your_upstox_access_token_here

# ── Claude / Anthropic API ─────────────

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Telegram Bot ───────────────────────

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Redis ──────────────────────────────

# Redis नसेल तर खाली line empty ठेवू शकतोस, पण live use साठी Redis better

REDIS_URL=redis://default:password@host:port

# ── Koyeb Web Service ──────────────────

PORT=8000

# ── Bot Risk / Signal Settings ─────────

MAX_DAY_SIGNALS=6
SIGNAL_EXPIRY=45
MIN_RR=1.5
MAX_ENTRY_DISTANCE=40
